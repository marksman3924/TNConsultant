<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TN Consultant: Strategic STP Analysis & KSF Profiling</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-annotation@3.0.1/dist/chartjs-plugin-annotation.min.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700;800&display=swap" rel="stylesheet">
    
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #f8fafc; color: #1e293b; scroll-behavior: smooth; }
        .chart-container { position: relative; width: 100%; max-width: 800px; margin: 0 auto; height: 400px; }
        .action-chart-container { position: relative; width: 100%; max-width: 900px; margin: 0 auto; height: 500px; }
        @media (min-width: 768px) { .chart-container { height: 450px; } .action-chart-container { height: 550px; } }
        .section-card { background-color: white; border-radius: 0.75rem; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1); padding: 2rem; margin-bottom: 2rem; border-top: 5px solid #1e3a8a; }
        .ksf-table th { background-color: #f1f5f9; color: #1e3a8a; font-weight: 600; padding: 1rem; text-align: left; }
        .ksf-table td { padding: 1rem; border-bottom: 1px solid #e2e8f0; }
        .bmc-grid { display: grid; gap: 1rem; grid-template-columns: repeat(1, 1fr); }
        @media (min-width: 1024px) { 
            .bmc-grid { grid-template-columns: repeat(5, 1fr); grid-template-rows: repeat(2, minmax(150px, auto)) auto; }
            .bmc-partners { grid-column: 1/2; grid-row: 1/3; } .bmc-activities { grid-column: 2/3; grid-row: 1/2; }
            .bmc-resources { grid-column: 2/3; grid-row: 2/3; } .bmc-value { grid-column: 3/4; grid-row: 1/3; }
            .bmc-relationships { grid-column: 4/5; grid-row: 1/2; } .bmc-channels { grid-column: 4/5; grid-row: 2/3; }
            .bmc-segments { grid-column: 5/6; grid-row: 1/3; } .bmc-cost { grid-column: 1/4; grid-row: 3/4; }
            .bmc-revenue { grid-column: 4/6; grid-row: 3/4; }
        }
        .bmc-box { background: #fff; padding: 0.75rem; border-radius: 0.5rem; border: 1px solid #e2e8f0; font-size: 0.8rem; }
        .bmc-title { font-size: 0.7rem; text-transform: uppercase; color: #64748b; font-weight: 700; margin-bottom: 0.5rem; border-bottom: 1px solid #f1f5f9; }
        .swot-item { display: flex; align-items: flex-start; margin-bottom: 0.75rem; }
        .swot-icon { margin-right: 0.75rem; flex-shrink: 0; font-weight: bold; }
    </style>
</head>
<body class="bg-slate-50">

    <!-- Header -->
    <header class="bg-slate-900 text-white py-4 px-4 shadow-xl sticky top-0 z-50">
        <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center">
            <div class="text-xl font-bold tracking-tight mb-2 md:mb-0">TN Consultant <span class="text-orange-500 text-sm font-normal">| Strategic Report</span></div>
            <nav class="flex space-x-4 text-xs md:text-sm font-medium text-slate-300">
                <a href="#quadrant" class="hover:text-white transition">Positioning</a>
                <a href="#ksf" class="hover:text-white transition">KSF Analysis</a>
                <a href="#data-summary" class="hover:text-white transition">Data Summary</a>
                <a href="#competitor-bmc" class="text-orange-400 hover:text-white transition border border-orange-500 rounded px-2 py-1">Joey Yap BMC</a>
                <a href="#action-plan" class="bg-orange-600 text-white px-3 py-1 rounded font-bold hover:bg-orange-700 transition">Action Plan</a>
            </nav>
        </div>
    </header>

    <main class="max-w-7xl mx-auto px-4 py-8">

        <!-- Intro -->
        <div class="mb-10 text-center max-w-4xl mx-auto pt-4">
            <h1 class="text-3xl md:text-5xl font-bold mb-3 tracking-tight text-slate-900">Strategic Market Analysis</h1>
            <p class="text-lg text-slate-600 leading-relaxed">Định vị <strong>TN Consultant</strong>: Metaphysics Strategist cho doanh chủ SME.</p>
        </div>

        <!-- Section 1: Quadrant (FIXED) -->
        <div id="quadrant" class="section-card">
            <h3 class="text-2xl font-bold text-slate-900 mb-6">1. Strategic Positioning Map</h3>
            <div class="chart-container"><canvas id="positioningScatterChart"></canvas></div>
        </div>

        <!-- Section 2: KSF -->
        <div id="ksf" class="section-card">
            <h3 class="text-2xl font-bold text-slate-900 mb-6">2. Key Success Factors (Scale 1-10)</h3>
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
                <div class="lg:col-span-2"><div class="chart-container"><canvas id="ksfLineChart"></canvas></div></div>
                <div class="space-y-4">
                    <div class="bg-orange-50 p-4 rounded-lg border border-orange-200">
                        <h4 class="font-bold text-orange-800">Your Edge</h4>
                        <p class="text-sm text-orange-900 mt-1">Vượt trội ở <strong>Tư duy Kinh doanh</strong> và <strong>Tính Thực dụng</strong>.</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Section 3: Data Summary -->
        <div id="data-summary" class="section-card">
            <h3 class="text-2xl font-bold text-slate-900 mb-4">3. Strategic Data Summary</h3>
            <div class="overflow-x-auto rounded-lg border border-slate-200">
                <table class="w-full text-sm text-left ksf-table">
                    <thead>
                        <tr>
                            <th class="rounded-tl-lg">KSF Criteria</th>
                            <th>TN Consultant <span class="text-xs font-normal text-orange-600">(You)</span></th>
                            <th>Joey Yap <span class="text-xs font-normal text-red-600">(Benchmark)</span></th>
                            <th>Traditional Masters</th>
                            <th class="rounded-tr-lg">Mass Pop-Science</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr><td class="font-medium">1. Học thuật</td><td class="text-orange-600 font-bold">7.0</td><td>9.5</td><td class="text-purple-600 font-bold">9.0</td><td>4.0</td></tr>
                        <tr><td class="font-medium">2. Tư duy KD</td><td class="text-orange-600 font-bold">9.0</td><td>9.5</td><td>3.0</td><td>5.0</td></tr>
                        <tr><td class="font-medium">3. Thương hiệu</td><td>4.0</td><td class="text-red-600 font-bold">10.0</td><td>7.0</td><td>8.5</td></tr>
                        <tr><td class="font-medium">4. Trải nghiệm</td><td class="text-orange-600 font-bold">8.0</td><td>9.0</td><td>4.0</td><td>7.0</td></tr>
                        <tr><td class="font-medium">5. Công nghệ</td><td>8.5</td><td>9.0</td><td>2.0</td><td class="text-blue-600 font-bold">9.0</td></tr>
                        <tr><td class="font-medium">6. Thực dụng</td><td class="text-orange-600 font-bold">9.5</td><td>9.5</td><td>4.0</td><td>6.0</td></tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Section 4: SWOT -->
        <div id="swot" class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
            <div class="section-card border-l-emerald-500 mb-0">
                <h3 class="text-xl font-bold text-slate-900 mb-4 flex items-center"><span class="text-emerald-500 mr-2">●</span> Strengths</h3>
                <div class="swot-item"><span class="swot-icon text-emerald-600">✓</span> Engineer Mindset & Trinity Method</div>
            </div>
            <div class="section-card border-l-red-500 mb-0">
                <h3 class="text-xl font-bold text-slate-900 mb-4 flex items-center"><span class="text-red-500 mr-2">●</span> Weaknesses</h3>
                <div class="swot-item"><span class="swot-icon text-red-600">!</span> Brand Collision & Ambiguous Title</div>
            </div>
        </div>

        <!-- Section 5: Competitor Reference -->
        <div id="competitor-bmc" class="section-card bg-slate-50 border-l-slate-400">
            <h3 class="text-xl font-bold text-slate-700 mb-4 uppercase tracking-wider">Reference: Joey Yap Business Model</h3>
            <div class="bmc-grid">
                <div class="bmc-box bmc-partners"><div class="bmc-title">Key Partners</div>FSA Organizers, Amazon, Tech</div>
                <div class="bmc-box bmc-activities"><div class="bmc-title">Key Activities</div>Seminars, Content, Training</div>
                <div class="bmc-box bmc-resources"><div class="bmc-title">Key Resources</div>IP, Content Library, Database</div>
                <div class="bmc-box bmc-value bg-red-50 border-red-200"><div class="bmc-title text-red-700">Value Prop</div>Scientific, Actionable, Global Authority</div>
                <div class="bmc-box bmc-relationships"><div class="bmc-title">Relationships</div>Tribal Community</div>
                <div class="bmc-box bmc-channels"><div class="bmc-title">Channels</div>Social, LMS, Seminars</div>
                <div class="bmc-box bmc-segments"><div class="bmc-title">Segments</div>SME Owners (Core)</div>
                <div class="bmc-box bmc-cost"><div class="bmc-title">Costs</div>Ads (CAC), Tech, Team</div>
                <div class="bmc-box bmc-revenue bg-green-50 border-green-200"><div class="bmc-title text-green-700">Revenue</div>Books (Low) -> Courses (Mid) -> Consulting (High)</div>
            </div>
        </div>

        <!-- Section 6: Action Plan (Fixed Padding) -->
        <div id="action-plan" class="section-card border-t-8 border-t-orange-600">
            <div class="flex justify-between items-center mb-6">
                <div>
                    <h3 class="text-3xl font-bold text-slate-900">6. Strategic Gap Analysis & Actions</h3>
                    <p class="text-slate-500 italic mt-1">Phân tích khoảng trống chiến lược để chọn ra hành động ưu tiên.</p>
                </div>
            </div>
            
            <div class="action-chart-container">
                <canvas id="actionPlanChart"></canvas>
            </div>

            <div class="mt-8 grid grid-cols-1 md:grid-cols-2 gap-6 text-sm">
                <div class="p-5 bg-emerald-50 border-l-4 border-emerald-500 rounded-r shadow-sm">
                    <h4 class="font-bold text-emerald-900 text-lg mb-2">ACTION 01: Leverage Tech & Mindset</h4>
                    <p class="text-emerald-800 mb-2 font-semibold">"Tiệm cận Benchmark & Vượt trội đối thủ"</p>
                    <p class="text-slate-700 leading-relaxed">Đây là vùng <strong>Sức mạnh cốt lõi</strong> của bạn. Bạn ngang ngửa Joey Yap về tư duy quản trị và ứng dụng công nghệ, bỏ xa các thầy truyền thống. Hãy dùng AI Report làm phễu và Case study kinh doanh để dominate ngách SME.</p>
                </div>
                <div class="p-5 bg-slate-50 border-l-4 border-slate-500 rounded-r shadow-sm">
                    <h4 class="font-bold text-slate-900 text-lg mb-2">ACTION 02: Narrow the Brand Gap</h4>
                    <p class="text-slate-800 mb-2 font-semibold">"Thu hẹp khoảng cách với Traditional Masters"</p>
                    <p class="text-slate-700 leading-relaxed">Thương hiệu là điểm yếu lớn nhất (4.0) so với nhóm Traditional (7.0). Chiến lược không phải là đối đầu về tâm linh huyền bí, mà là xây dựng Trust thông qua sự minh bạch (Transparency) và kết quả thực tế (Results).</p>
                </div>
            </div>
        </div>

    </main>
    
    <footer class="bg-slate-900 text-slate-400 py-6 text-center text-sm"><p>© 2025 TN Consultant.</p></footer>

    <script>
        Chart.defaults.font.family = "'Inter', sans-serif";
        Chart.defaults.color = '#64748b';
        Chart.register(window['chartjs-plugin-annotation']);

        // --- CHART 1: QUADRANT PLOT (FIXED AREAS & AXIS) ---
        const quadrantPlugin = {
            id: 'quadrants',
            beforeDraw(chart, args, options) {
                const {ctx, chartArea: {left, top, right, bottom}, scales: {x, y}} = chart;
                const midX = x.getPixelForValue(5);
                const midY = y.getPixelForValue(5);

                ctx.save();
                // Draw 4 Colored Areas
                ctx.fillStyle = 'rgba(240, 253, 244, 0.5)'; ctx.fillRect(midX, top, right - midX, midY - top); // Q1
                ctx.fillStyle = 'rgba(254, 252, 232, 0.5)'; ctx.fillRect(left, top, midX - left, midY - top); // Q2
                ctx.fillStyle = 'rgba(241, 245, 249, 0.5)'; ctx.fillRect(left, midY, midX - left, bottom - midY); // Q3
                ctx.fillStyle = 'rgba(250, 245, 255, 0.5)'; ctx.fillRect(midX, midY, right - midX, bottom - midY); // Q4
                ctx.restore();
                
                // Draw Dashed Axes lines
                ctx.save();
                ctx.beginPath(); ctx.moveTo(midX, top); ctx.lineTo(midX, bottom); ctx.moveTo(left, midY); ctx.lineTo(right, midY);
                ctx.strokeStyle = '#94a3b8'; ctx.lineWidth = 1; ctx.setLineDash([5, 5]); ctx.stroke(); ctx.restore();

                // Draw Labels
                ctx.font = 'bold 12px Inter'; ctx.fillStyle = '#64748b'; ctx.textAlign = 'center';
                ctx.fillText('STRATEGIC ADVISORS', (midX + right)/2, top + 20);
                ctx.fillText('LIFE COACHES', (left + midX)/2, top + 20);
                ctx.fillText('FORTUNE TELLERS', (left + midX)/2, bottom - 10);
                ctx.fillText('ACADEMIC', (midX + right)/2, bottom - 10);
            }
        };

        new Chart(document.getElementById('positioningScatterChart'), {
            type: 'scatter',
            data: {
                datasets: [
                    { label: 'TN Consultant', data: [{x: 8.5, y: 9.0}], backgroundColor: '#f97316', pointRadius: 15 },
                    { label: 'Joey Yap', data: [{x: 9.5, y: 9.5}], backgroundColor: '#ef4444', pointRadius: 12 },
                    { label: 'Traditional Masters', data: [{x: 7.0, y: 3.0}], backgroundColor: '#8b5cf6', pointRadius: 10 },
                    { label: 'Mass Pop-Science', data: [{x: 3.0, y: 4.0}], backgroundColor: '#3b82f6', pointRadius: 8 }
                ]
            },
            options: {
                responsive: true, maintainAspectRatio: false,
                scales: {
                    // Enabled Axis Titles
                    x: { min: 0, max: 10, display: true, grid: {display: false}, title: {display: true, text: 'Scientific Methodology (Tính Khoa học)', font: {weight: 'bold'}} },
                    y: { min: 0, max: 10, display: true, grid: {display: false}, title: {display: true, text: 'Solution Oriented (Tính Giải pháp)', font: {weight: 'bold'}} }
                },
                plugins: { legend: { position: 'bottom' } }
            },
            plugins: [quadrantPlugin] // ATTACHED PLUGIN HERE
        });

        // KSF Data
        const ksfLabels = ['Học thuật', 'Tư duy KD', 'Thương hiệu', 'Trải nghiệm', 'Công nghệ', 'Thực dụng'];
        
        // --- CHART 2: KSF Full ---
        new Chart(document.getElementById('ksfLineChart'), {
            type: 'line',
            data: {
                labels: ksfLabels,
                datasets: [
                    { label: 'TN Consultant', data: [7, 9, 4, 8, 8.5, 9.5], borderColor: '#f97316', backgroundColor: 'rgba(249, 115, 22, 0.1)', borderWidth: 4, tension: 0.4 },
                    { label: 'Traditional Masters', data: [9, 3, 7, 4, 2, 4], borderColor: '#8b5cf6', borderWidth: 2, borderDash: [5, 5], tension: 0.4 },
                    { label: 'Mass Pop-Science', data: [4, 5, 8.5, 7, 9, 6], borderColor: '#3b82f6', borderWidth: 2, borderDash: [5, 5], tension: 0.4 },
                    { label: 'Joey Yap', data: [9.5, 9.5, 10, 9, 9, 9.5], borderColor: '#ef4444', borderWidth: 1, tension: 0.4 }
                ]
            },
            options: {
                responsive: true, maintainAspectRatio: false,
                scales: { y: { beginAtZero: true, max: 10.5 }, x: { grid: { display: false } } }
            }
        });

        // --- CHART 3: STRATEGIC GAP ANALYSIS (MINIMALIST REFINED) ---
        new Chart(document.getElementById('actionPlanChart'), {
            type: 'line',
            data: {
                labels: ksfLabels,
                datasets: [
                    // Main Curves
                    { 
                        label: 'TN Consultant (You)', 
                        data: [7, 9, 4, 8, 8.5, 9.5], 
                        borderColor: '#f97316', borderWidth: 4, tension: 0.4, pointRadius: 0, z: 20
                    },
                    { 
                        label: 'Joey Yap (Benchmark)', 
                        data: [9.5, 9.5, 10, 9, 9, 9.5], 
                        borderColor: '#1e293b', borderWidth: 1.5, tension: 0.4, pointRadius: 0, z: 10 // Black Solid
                    },
                    { 
                        label: 'Traditional Masters', 
                        data: [9, 3, 7, 4, 2, 4], 
                        borderColor: '#94a3b8', borderWidth: 2, borderDash: [4, 4], tension: 0.4, pointRadius: 0, z: 5 // Gray Dotted
                    },

                    // --- FILL DATASETS ---
                    {
                        label: 'Fill Top',
                        data: [null, 9.5, 10, 9.0, null, null], // JY values
                        borderColor: 'transparent', pointRadius: 0, fill: false, tension: 0.4
                    },
                    {
                        label: 'Fill Bottom',
                        data: [null, 9.0, 4.0, 8.0, null, null], // TN values
                        borderColor: 'transparent', pointRadius: 0, tension: 0.4,
                        fill: {
                            target: '-1', 
                            above: 'rgba(203, 213, 225, 0.4)' // Subtle Slate Gray Fill for Gap
                        }
                    }
                ]
            },
            options: {
                responsive: true, maintainAspectRatio: false,
                layout: {
                    padding: { left: 40, right: 40, top: 20, bottom: 20 }
                },
                scales: { 
                    y: { display: false, min: 0, max: 12 }, 
                    x: { 
                        grid: { display: false }, 
                        ticks: { font: { size: 12, weight: 'bold' }, color: '#334155', padding: 10 } 
                    } 
                },
                plugins: {
                    legend: { 
                        position: 'bottom', 
                        labels: { usePointStyle: true, padding: 20, filter: item => !item.text.includes('Fill') } 
                    },
                    annotation: {
                        clip: false,
                        annotations: {
                            // --- CIRCLES ---
                            gapCircleBiz: { type: 'point', xValue: 1, yValue: 9.25, radius: 15, backgroundColor: 'rgba(20, 184, 166, 0.1)', borderColor: '#14b8a6', borderWidth: 1.5 },
                            gapCircleTech: { type: 'point', xValue: 4, yValue: 8.75, radius: 15, backgroundColor: 'rgba(20, 184, 166, 0.1)', borderColor: '#14b8a6', borderWidth: 1.5 },

                            // --- ARROW (Refined & Minimal) ---
                            arrowBrand: {
                                type: 'line', xMin: 2, xMax: 2, yMin: 4.5, yMax: 9.5,
                                borderColor: '#64748b', borderWidth: 1, borderDash: [4, 4], // Fine dashed gray line
                                arrowHeads: { end: { display: true, fill: true, length: 6, width: 4, borderColor: '#64748b', backgroundColor: '#64748b' } }
                            },
                            labelGap: {
                                type: 'label', xValue: 2, yValue: 7, content: 'Gap Analysis', 
                                backgroundColor: 'white', color: '#64748b', font: {size: 9, style:'italic'}, borderRadius: 4, padding: 3
                            },

                            // --- LABELS (Minimalist Black/Gray) ---
                            jySig1: { type: 'label', xValue: 0, yValue: 10.5, content: ['Mastery', '(Học thuật)'], color: '#334155', font: {size: 10}, textAlign: 'left', xAdjust: 20 },
                            jySig2: { type: 'label', xValue: 2, yValue: 10.8, content: ['Global Brand', '(Thương hiệu)'], color: '#334155', font: {size: 10} },
                            jySig3: { type: 'label', xValue: 5, yValue: 10.2, content: ['Actionable', '(Thực dụng)'], color: '#334155', font: {size: 10}, textAlign: 'right', xAdjust: -20 },

                            userSit1: { type: 'label', xValue: 1, yValue: 8.2, content: ['Strong Mindset'], color: '#f97316', font: {size: 10} },
                            userSit2: { type: 'label', xValue: 2, yValue: 3.2, content: ['Low Visibility'], color: '#f97316', font: {size: 10} },
                            userSit3: { type: 'label', xValue: 4, yValue: 7.8, content: ['High Tech'], color: '#f97316', font: {size: 10} }
                        }
                    }
                }
            }
        });
    </script>
</body>
</html>
